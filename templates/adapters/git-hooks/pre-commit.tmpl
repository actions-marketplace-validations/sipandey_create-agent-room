#!/bin/sh
# Git pre-commit hook generated by create-agent-room
# Runs the guardrails check for all commits. Kept narrow and fast on
# purpose: closing-the-loop discipline (did this turn log a decision or
# anti-pattern?) is enforced separately by the Claude Code Stop hook
# (.agent-room/hooks/close-the-loop-check.js), which is scoped to agent
# sessions rather than every human commit, and doesn't share a hook with
# this security-relevant check.

if ! [ -d ".agent-room" ]; then
  exit 0
fi

if [ -f ".agent-room/hooks/guardrails-check.js" ]; then
  node ".agent-room/hooks/guardrails-check.js"
  if [ $? -ne 0 ]; then
    exit 1
  fi
fi
